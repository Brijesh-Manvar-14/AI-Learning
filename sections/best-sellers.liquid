{%- comment -%}
  Best Sellers Section — Waymakers Theme
  Slick Carousel CDN loaded once per page render via Liquid scope guard.
{%- endcomment -%}

{% unless slick_loaded %}
  {% assign slick_loaded = true %}
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css">
  <script src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js" defer></script>
{% endunless %}

{%- assign bs_collection = collections[section.settings.collection] -%}
{%- unless bs_collection -%}
  {%- assign bs_collection = collections['all'] -%}
{%- endunless -%}

<section
  class="bs-section"
  id="best-sellers-{{ section.id }}"
  style="--bs-bg: {{ section.settings.background_color }}; --bs-color: {{ section.settings.text_color }};"
>
  <div class="bs-container">

    {%- comment -%} ── Header row: heading left · view-all right ── {%- endcomment -%}
    <header class="bs-head">
      <h2 class="bs-head__title">
        {{- section.settings.heading | default: 'Best Sellers' -}}
        <svg class="bs-head__star" viewBox="0 0 24 24" width="36" height="36" aria-hidden="true" focusable="false">
          <path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01L12 2z" fill="#ffd11f" stroke="#000" stroke-width="1.2" stroke-linejoin="round"/>
        </svg>
      </h2>
      {%- if section.settings.view_all_label != blank and section.settings.view_all_link != blank -%}
        <a href="{{ section.settings.view_all_link }}" class="bs-btn-viewall">
          {{- section.settings.view_all_label -}}
          <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true" focusable="false">
            <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
        </a>
      {%- endif -%}
    </header>

    {%- comment -%} ── Slider ── {%- endcomment -%}
    <div
      class="bs-slider"
      data-autoplay="{{ section.settings.autoplay }}"
      data-autoplay-speed="{{ section.settings.autoplay_speed }}"
      role="list"
      aria-label="{{ section.settings.heading | default: 'Best Sellers' | escape }}"
    >

      {%- for product in bs_collection.products limit: section.settings.products_to_show -%}
        {%- assign bs_on_sale = false -%}
        {%- if product.compare_at_price > product.price -%}
          {%- assign bs_on_sale = true -%}
        {%- endif -%}
        {%- assign bs_default_variant = false -%}
        {%- if product.variants.size == 1 and product.variants.first.title == 'Default Title' -%}
          {%- assign bs_default_variant = true -%}
        {%- endif -%}

        <div class="bs-slide" role="listitem">
          <article class="bs-card">

            <div class="bs-card__media">
              <a href="{{ product.url }}" aria-label="{{ product.title | escape }}" tabindex="-1">
                <img
                  class="bs-card__img bs-card__img--primary"
                  src="{{ product.featured_image | img_url: '600x600', crop: 'center' }}"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  width="600"
                  height="600"
                  loading="lazy"
                >
                {%- if product.images.size > 1 -%}
                  <img
                    class="bs-card__img bs-card__img--secondary"
                    src="{{ product.images[1] | img_url: '600x600', crop: 'center' }}"
                    alt="{{ product.images[1].alt | default: product.title | escape }}"
                    width="600"
                    height="600"
                    loading="lazy"
                  >
                {%- endif -%}
              </a>
              {%- if bs_on_sale and section.settings.show_sale_badge -%}
                <span class="bs-card__badge" aria-label="On sale">SALE</span>
              {%- endif -%}
            </div>

            <div class="bs-card__info">
              {%- if section.settings.show_vendor -%}
                <p class="bs-card__vendor">{{ product.vendor }}</p>
              {%- endif -%}

              <h3 class="bs-card__title">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>

              <div class="bs-card__rating" role="img" aria-label="4.5 out of 5 stars">
                {%- for i in (1..4) -%}
                  <svg viewBox="0 0 20 20" width="13" height="13" aria-hidden="true" focusable="false" fill="#ffd11f">
                    <path d="M10 15.27L16.18 19l-1.64-7.03L20 7.24l-7.19-.61L10 0 7.19 6.63 0 7.24l5.46 4.73L3.82 19z"/>
                  </svg>
                {%- endfor -%}
                <svg viewBox="0 0 20 20" width="13" height="13" aria-hidden="true" focusable="false">
                  <defs>
                    <linearGradient id="bs-half-{{ section.id }}">
                      <stop offset="50%" stop-color="#ffd11f"/>
                      <stop offset="50%" stop-color="#e0e0e0"/>
                    </linearGradient>
                  </defs>
                  <path d="M10 15.27L16.18 19l-1.64-7.03L20 7.24l-7.19-.61L10 0 7.19 6.63 0 7.24l5.46 4.73L3.82 19z" fill="url(#bs-half-{{ section.id }})"/>
                </svg>
              </div>

              <div class="bs-card__price">
                {%- if bs_on_sale -%}
                  <s class="bs-card__price--compare">{{ product.compare_at_price | money }}</s>
                  <span class="bs-card__price--sale">{{ product.price | money }}</span>
                {%- else -%}
                  <span class="bs-card__price--regular">{{ product.price | money }}</span>
                {%- endif -%}
              </div>

              {%- if bs_default_variant -%}
                <button
                  class="bs-card__btn"
                  type="button"
                  data-variant-id="{{ product.variants.first.id }}"
                  data-label="{{ section.settings.button_label | escape }}"
                  aria-label="Add {{ product.title | escape }} to cart"
                >
                  {{- section.settings.button_label -}}
                </button>
              {%- else -%}
                <a
                  href="{{ product.url }}"
                  class="bs-card__btn bs-card__btn--link"
                  aria-label="Select options for {{ product.title | escape }}"
                >
                  Select options
                </a>
              {%- endif -%}

              <p class="bs-card__error" role="alert" aria-live="polite" hidden></p>
            </div>

          </article>
        </div>

      {%- else -%}

        {%- for i in (1..4) -%}
          <div class="bs-slide" role="listitem">
            <article class="bs-card bs-card--placeholder" aria-hidden="true">
              <div class="bs-card__media">
                {{ 'product-1' | placeholder_svg_tag: 'bs-card__placeholder-img' }}
              </div>
              <div class="bs-card__info">
                <h3 class="bs-card__title">Product Title</h3>
                <div class="bs-card__rating" aria-hidden="true">
                  {%- for i in (1..5) -%}
                    <svg viewBox="0 0 20 20" width="13" height="13" fill="#e0e0e0" aria-hidden="true"><path d="M10 15.27L16.18 19l-1.64-7.03L20 7.24l-7.19-.61L10 0 7.19 6.63 0 7.24l5.46 4.73L3.82 19z"/></svg>
                  {%- endfor -%}
                </div>
                <div class="bs-card__price">
                  <span class="bs-card__price--regular">€0,00</span>
                </div>
                <button class="bs-card__btn" type="button" disabled>
                  {{ section.settings.button_label }}
                </button>
              </div>
            </article>
          </div>
        {%- endfor -%}

      {%- endfor -%}
    </div>

  </div>
</section>

{% stylesheet %}
/* ==========================================================
   BEST SELLERS — Waymakers Theme
   Pixel-matched from Figma: white bg · left heading + star ·
   right view-all · 4-col Slick · yellow CTA button
   ========================================================== */

.bs-section {
  background-color: var(--bs-bg, #ffffff);
  color: var(--bs-color, #000000);
  padding-top: 60px;
  padding-bottom: 72px;
}

.bs-container {
  width: min(1500px, calc(100vw - 48px));
  margin-inline: auto;
}

/* ----------------------------------------------------------
   SECTION HEADER — flex row, heading left · button right
   ---------------------------------------------------------- */
.bs-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 32px;
  flex-wrap: wrap;
}

.bs-head__title {
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: "Lilita One", serif;
  font-size: 56px;
  font-weight: 400;
  line-height: 1.1;
  text-transform: uppercase;
  color: inherit;
  margin: 0;
}

.bs-head__star {
  flex-shrink: 0;
  display: inline-block;
  vertical-align: middle;
}

/* View-all button — outlined pill, inline with heading */
.bs-btn-viewall {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
  padding: 10px 24px;
  height: 44px;
  background: transparent;
  color: #000000;
  border: 1.5px solid #000000;
  border-right-width: 3px;
  border-bottom-width: 3px;
  border-radius: 61px;
  font-family: Kanit, var(--font-body-family, sans-serif);
  font-size: 14px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  text-decoration: none;
  white-space: nowrap;
  transition: background 0.2s ease, transform 0.1s ease;
}

.bs-btn-viewall:hover {
  background: #ffd11f;
}

.bs-btn-viewall:active {
  transform: translate(2px, 2px);
}

/* ----------------------------------------------------------
   SLIDER WRAPPER
   ---------------------------------------------------------- */
.bs-slider {
  /* horizontal padding leaves room for the nav arrows */
  padding: 0 52px;
  margin-bottom: 0;
}

.bs-slide {
  padding: 0 8px;
}

/* ----------------------------------------------------------
   PRODUCT CARD
   ---------------------------------------------------------- */
.bs-card {
  background: #ffffff;
  border: 1.5px solid #000000;
  border-right-width: 3px;
  border-bottom-width: 3px;
  border-radius: 8px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: box-shadow 0.18s ease, transform 0.18s ease;
}

.bs-card:hover {
  box-shadow: 4px 4px 0 #000000;
  transform: translate(-2px, -2px);
}

/* Media */
.bs-card__media {
  position: relative;
  overflow: hidden;
  background: #f7f7f7;
  aspect-ratio: 1 / 1;
  border-radius: 6px 6px 0 0;
}

.bs-card__media > a {
  display: block;
  width: 100%;
  height: 100%;
  position: relative;
}

.bs-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  transition: opacity 0.28s ease;
}

.bs-card__img--secondary {
  position: absolute;
  inset: 0;
  opacity: 0;
}

.bs-card__media:hover .bs-card__img--primary {
  opacity: 0;
}

.bs-card__media:hover .bs-card__img--secondary {
  opacity: 1;
}

.bs-card__placeholder-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Sale badge */
.bs-card__badge {
  position: absolute;
  top: 10px;
  left: 10px;
  z-index: 2;
  background: #ffd11f;
  color: #000000;
  font-family: Kanit, var(--font-body-family, sans-serif);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  line-height: 1;
  padding: 5px 10px;
  border: 1px solid #000000;
  border-right-width: 2px;
  border-bottom-width: 2px;
  border-radius: 4px;
  pointer-events: none;
}

/* Card info */
.bs-card__info {
  padding: 14px 16px 18px;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.bs-card__vendor {
  font-family: Kanit, var(--font-body-family, sans-serif);
  font-size: 11px;
  font-weight: 400;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #888888;
  margin: 0 0 4px;
}

.bs-card__title {
  font-family: Kanit, var(--font-body-family, sans-serif);
  font-size: 13px;
  font-weight: 600;
  line-height: 1.4;
  text-transform: uppercase;
  margin: 0 0 8px;
  min-height: 36px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.bs-card__title a {
  color: inherit;
  text-decoration: none;
}

.bs-card__title a:hover {
  text-decoration: underline;
}

/* Star rating */
.bs-card__rating {
  display: flex;
  align-items: center;
  gap: 2px;
  margin-bottom: 8px;
}

/* Price */
.bs-card__price {
  display: flex;
  align-items: baseline;
  gap: 7px;
  margin-bottom: 12px;
  flex-wrap: wrap;
}

.bs-card__price--regular,
.bs-card__price--sale {
  font-family: Kanit, var(--font-body-family, sans-serif);
  font-size: 16px;
  font-weight: 700;
  line-height: 1.2;
  color: inherit;
}

.bs-card__price--sale {
  color: #c0392b;
}

.bs-card__price--compare {
  font-family: Kanit, var(--font-body-family, sans-serif);
  font-size: 12px;
  font-weight: 400;
  color: #aaaaaa;
  text-decoration: line-through;
}

/* Add to Cart button — YELLOW as per Figma */
.bs-card__btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 44px;
  padding: 10px 16px;
  margin-top: auto;
  background: #ffd11f;
  color: #000000;
  border: 1.5px solid #000000;
  border-right-width: 3px;
  border-bottom-width: 3px;
  border-radius: 61px;
  font-family: Kanit, var(--font-body-family, sans-serif);
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  cursor: pointer;
  text-decoration: none;
  transition: background 0.2s ease, transform 0.1s ease;
  line-height: 1;
}

.bs-card__btn:hover:not(:disabled) {
  background: #f5c800;
}

.bs-card__btn:active:not(:disabled) {
  transform: translate(2px, 2px);
}

.bs-card__btn:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

.bs-card__error {
  font-family: Kanit, var(--font-body-family, sans-serif);
  font-size: 11px;
  color: #c0392b;
  margin: 6px 0 0;
}

/* Placeholder */
.bs-card--placeholder .bs-card__media {
  background: #efefef;
}

/* ----------------------------------------------------------
   SLICK OVERRIDES
   High-specificity (.bs-section .bs-slider) to win over
   slick-theme.css loaded later via CDN body link.
   ---------------------------------------------------------- */

/* Equal-height slides */
.bs-section .bs-slider .slick-track {
  display: flex;
  align-items: stretch;
}

.bs-section .bs-slider .slick-slide {
  height: auto;
}

.bs-section .bs-slider .slick-slide > div {
  height: 100%;
}

.bs-section .bs-slider .bs-slide {
  height: 100%;
}

.bs-section .bs-slider .bs-card {
  height: 100%;
}

/* Navigation arrows */
.bs-section .bs-slider .slick-prev,
.bs-section .bs-slider .slick-next {
  width: 44px;
  height: 44px;
  background: #ffffff;
  border: 1.5px solid #000000;
  border-right-width: 3px;
  border-bottom-width: 3px;
  border-radius: 50%;
  z-index: 10;
  top: 38%;
  transition: background 0.18s ease;
}

.bs-section .bs-slider .slick-prev:hover,
.bs-section .bs-slider .slick-next:hover {
  background: #ffd11f;
}

.bs-section .bs-slider .slick-prev:active,
.bs-section .bs-slider .slick-next:active {
  transform: translateY(-50%) translate(2px, 2px);
}

.bs-section .bs-slider .slick-prev {
  left: 0;
}

.bs-section .bs-slider .slick-next {
  right: 0;
}

/* Arrow chevrons via ::before */
.bs-section .bs-slider .slick-prev::before,
.bs-section .bs-slider .slick-next::before {
  content: '';
  display: block;
  width: 9px;
  height: 9px;
  border-top: 2px solid #000000;
  border-right: 2px solid #000000;
  position: absolute;
  top: 50%;
  left: 50%;
  opacity: 1;
  font-size: 0;
}

.bs-section .bs-slider .slick-prev::before {
  transform: translate(-30%, -50%) rotate(-135deg);
}

.bs-section .bs-slider .slick-next::before {
  transform: translate(-70%, -50%) rotate(45deg);
}

/* Dots */
.bs-section .bs-slider .slick-dots {
  position: static;
  margin-top: 24px;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  list-style: none;
  line-height: 1;
}

.bs-section .bs-slider .slick-dots li {
  margin: 0 4px;
  width: 20px;
  height: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bs-section .bs-slider .slick-dots li button {
  width: 20px;
  height: 20px;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  cursor: pointer;
}

.bs-section .bs-slider .slick-dots li button::before {
  content: '';
  display: block;
  width: 8px;
  height: 8px;
  border: 2px solid #000000;
  border-radius: 50%;
  background: transparent;
  opacity: 1;
  position: static;
  font-size: 0;
  transition: background 0.18s ease;
}

.bs-section .bs-slider .slick-dots li.slick-active button::before {
  background: #000000;
}

/* ----------------------------------------------------------
   RESPONSIVE
   ---------------------------------------------------------- */
@media (max-width: 1100px) {
  .bs-head__title {
    font-size: 44px;
  }
}

@media (max-width: 768px) {
  .bs-section {
    padding-top: 48px;
    padding-bottom: 56px;
  }

  .bs-head {
    margin-bottom: 24px;
  }

  .bs-head__title {
    font-size: 34px;
  }

  .bs-head__star {
    width: 28px;
    height: 28px;
  }

  .bs-slider {
    padding: 0 42px;
  }
}

@media (max-width: 480px) {
  .bs-head__title {
    font-size: 28px;
  }

  .bs-head__star {
    width: 22px;
    height: 22px;
  }

  .bs-btn-viewall {
    font-size: 12px;
    padding: 8px 16px;
    height: 38px;
  }

  .bs-slider {
    padding: 0 36px;
  }

  .bs-section .bs-slider .slick-prev,
  .bs-section .bs-slider .slick-next {
    width: 36px;
    height: 36px;
  }
}
{% endstylesheet %}

{% javascript %}
(function () {
  'use strict';

  /* --------------------------------------------------------
     Add to Cart — Shopify Ajax Cart API
  -------------------------------------------------------- */
  async function addToCart(variantId, btn) {
    const originalLabel = btn.dataset.label;
    btn.textContent = 'Adding\u2026';
    btn.disabled = true;
    hideError(btn);
    try {
      const res = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 1 })
      });
      if (!res.ok) throw new Error('Cart error');
      btn.textContent = 'Added \u2713';
      const cart = await fetch('/cart.js').then(function (r) { return r.json(); });
      document.querySelectorAll('[data-cart-count]').forEach(function (el) {
        el.textContent = cart.item_count;
      });
      document.dispatchEvent(new CustomEvent('cart:updated', { detail: cart }));
      setTimeout(function () {
        btn.textContent = originalLabel;
        btn.disabled = false;
      }, 2000);
    } catch {
      btn.textContent = 'Try Again';
      btn.disabled = false;
      showError(btn, 'Something went wrong. Please try again.');
    }
  }

  function showError(btn, msg) {
    var el = btn.closest('.bs-card__info');
    if (!el) return;
    var errEl = el.querySelector('.bs-card__error');
    if (errEl) { errEl.textContent = msg; errEl.hidden = false; }
  }

  function hideError(btn) {
    var el = btn.closest('.bs-card__info');
    if (!el) return;
    var errEl = el.querySelector('.bs-card__error');
    if (errEl) errEl.hidden = true;
  }

  /* --------------------------------------------------------
     Delegated click — works after Slick re-renders DOM
  -------------------------------------------------------- */
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.bs-card__btn[data-variant-id]');
    if (!btn || btn.disabled) return;
    e.preventDefault();
    addToCart(Number(btn.dataset.variantId), btn);
  });

  /* --------------------------------------------------------
     Slick init — retries every 200ms until jQuery + Slick ready
  -------------------------------------------------------- */
  function initSliders() {
    document.querySelectorAll('.bs-slider:not([data-slick-init])').forEach(function (slider) {
      slider.setAttribute('data-slick-init', '1');
      var autoplay = slider.dataset.autoplay === 'true';
      var autoplaySpeed = parseInt(slider.dataset.autoplaySpeed, 10) || 4000;
      jQuery(slider).slick({
        slidesToShow: 4,
        slidesToScroll: 1,
        autoplay: autoplay,
        autoplaySpeed: autoplaySpeed,
        dots: true,
        arrows: true,
        infinite: true,
        speed: 400,
        lazyLoad: 'ondemand',
        responsive: [
          { breakpoint: 1025, settings: { slidesToShow: 3, slidesToScroll: 1 } },
          { breakpoint: 769,  settings: { slidesToShow: 2, slidesToScroll: 1 } },
          { breakpoint: 481,  settings: { slidesToShow: 1, slidesToScroll: 1 } }
        ]
      });
    });
  }

  function waitAndInit(n) {
    if (n <= 0) return;
    if (typeof jQuery !== 'undefined' && typeof jQuery.fn.slick !== 'undefined') {
      initSliders();
    } else {
      setTimeout(function () { waitAndInit(n - 1); }, 200);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () { waitAndInit(25); });
  } else {
    waitAndInit(25);
  }
}());
{% endjavascript %}

{% schema %}
{
  "name": "Best Sellers",
  "tag": "section",
  "class": "best-sellers-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Best Sellers"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Max products to show"
    },
    {
      "type": "checkbox",
      "id": "show_sale_badge",
      "label": "Show sale badge",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor / brand",
      "default": false
    },
    {
      "type": "text",
