{{ 'waymakers-home.css' | asset_url | stylesheet_tag }}
{{ 'quick-add.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'waymakers-home.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign arrow = 'wm-arrow.svg' | asset_url
  assign arrow_left = 'wm-arrow-left.svg' | asset_url
  assign fallback_product_1 = 'wm-product-1.png' | asset_url
  assign fallback_product_2 = 'wm-product-2.png' | asset_url
  assign fallback_product_3 = 'wm-product-3.png' | asset_url
  assign fallback_product_4 = 'wm-product-4.png' | asset_url
-%}

<section class="wm-container" aria-labelledby="wm-products-title-{{ section.id }}">
  <div class="wm-section-head">
    <h2 id="wm-products-title-{{ section.id }}" class="wm-heading">{{ section.settings.heading }}</h2>
    <span class="wm-section-head__line"></span>
    <a class="wm-button" href="{{ section.settings.button_link | default: routes.all_products_collection_url }}">
      {{ section.settings.button_label }}
      <img src="{{ arrow }}" alt="" width="8" height="13">
    </a>
  </div>

  <waymakers-slider class="wm-slider">
    <button class="wm-slider-arrow wm-slider-arrow--prev" type="button" data-wm-slider-prev aria-label="{{ 'general.slider.previous_slide' | t }}">
      <img src="{{ arrow_left }}" alt="" width="14" height="14">
    </button>

    <div class="wm-slider__track" data-wm-slider-track role="list">
      {%- assign rendered_products = 0 -%}
      {%- if section.settings.collection != blank and section.settings.collection.products_count > 0 -%}
        {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
          {%- assign rendered_products = rendered_products | plus: 1 -%}
          {% render 'waymakers-product-card',
            product: product,
            fallback_index: forloop.index,
            arrow: arrow,
            fallback_product_1: fallback_product_1,
            fallback_product_2: fallback_product_2,
            fallback_product_3: fallback_product_3,
            fallback_product_4: fallback_product_4,
            section_id: section.id
          %}
        {%- endfor -%}
      {%- endif -%}

      {%- if rendered_products == 0 -%}
        {%- for block in section.blocks -%}
          {%- assign rendered_products = rendered_products | plus: 1 -%}
          {% render 'waymakers-product-card',
            product: block.settings.product,
            title: block.settings.title,
            price_text: block.settings.price_text,
            image: block.settings.image,
            link: block.settings.link,
            fallback_index: rendered_products,
            arrow: arrow,
            fallback_product_1: fallback_product_1,
            fallback_product_2: fallback_product_2,
            fallback_product_3: fallback_product_3,
            fallback_product_4: fallback_product_4,
            section_id: section.id,
            block: block
          %}
        {%- endfor -%}
      {%- endif -%}
    </div>

    <button class="wm-slider-arrow wm-slider-arrow--next" type="button" data-wm-slider-next aria-label="{{ 'general.slider.next_slide' | t }}">
      <img src="{{ arrow_left }}" alt="" width="14" height="14">
    </button>
  </waymakers-slider>
</section>

{% schema %}
{
  "name": "WayMakers products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best Sellers ✨" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 4, "max": 12, "step": 1, "default": 4 },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Alle Producten" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Fallback product",
      "limit": 8,
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "image_picker", "id": "image", "label": "Image override" },
        { "type": "text", "id": "title", "label": "Title" },
        { "type": "text", "id": "price_text", "label": "Price text", "default": "$13.99" },
        { "type": "url", "id": "link", "label": "Fallback link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "WayMakers products",
      "blocks": [
        { "type": "product", "settings": { "title": "Frosted Brookie Peanut Butter Treat" } },
        { "type": "product", "settings": { "title": "Dubai chocolate bar Peanut Butter Treat" } },
        { "type": "product", "settings": { "title": "Blureos & Cream Milkshake Cashew Butter Treat" } },
        { "type": "product", "settings": { "title": "Ultimate PB Cheesecake Peanut Butter Treat" } }
      ]
    }
  ]
}
{% endschema %}
