{{ 'waymakers-home.css' | asset_url | stylesheet_tag }}
<script src="{{ 'waymakers-home.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign texture = 'wm-texture.png' | asset_url
  assign fallback = 'wm-product-3.png' | asset_url
  assign arrow_left = 'wm-arrow-left.svg' | asset_url
  if section.settings.texture != blank
    assign texture = section.settings.texture | image_url: width: 2200
  endif
-%}

<section class="wm-review wm-page" style="--wm-review-texture: url({{ texture }}); --wm-review-fallback: url({{ fallback }});" aria-labelledby="wm-review-title-{{ section.id }}">
  <div class="wm-review__inner">
    <h2 id="wm-review-title-{{ section.id }}" class="wm-heading">{{ section.settings.heading }}</h2>

    <waymakers-slider class="wm-slider">
      <button class="wm-slider-arrow wm-slider-arrow--prev" type="button" data-wm-slider-prev aria-label="{{ 'general.slider.previous_slide' | t }}">
        <img src="{{ arrow_left }}" alt="" width="14" height="14">
      </button>

      <div class="wm-slider__track" data-wm-slider-track role="list">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <article class="wm-video-card" role="listitem" data-wm-video-card {{ block.shopify_attributes }}>
              {%- if block.settings.video != blank -%}
                {{ block.settings.video | video_tag: image_size: '720x', autoplay: false, loop: false, muted: false, controls: true }}
              {%- elsif block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 720 }}" alt="{{ block.settings.alt | escape }}" loading="lazy" width="360" height="640">
              {%- else -%}
                <div class="wm-video-card__fallback">{{ block.settings.fallback_text }}</div>
              {%- endif -%}
              <span class="wm-play" aria-hidden="true"></span>
            </article>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..5) -%}
            <article class="wm-video-card" role="listitem" data-wm-video-card>
              <div class="wm-video-card__fallback">Nerdy<br>Nuts</div>
              <span class="wm-play" aria-hidden="true"></span>
            </article>
          {%- endfor -%}
        {%- endif -%}
      </div>

      <button class="wm-slider-arrow wm-slider-arrow--next" type="button" data-wm-slider-next aria-label="{{ 'general.slider.next_slide' | t }}">
        <img src="{{ arrow_left }}" alt="" width="14" height="14">
      </button>
    </waymakers-slider>
  </div>
</section>

{% schema %}
{
  "name": "WayMakers reviews",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Geproefd, getest & Geliefd!" },
    { "type": "image_picker", "id": "texture", "label": "Texture image" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review video",
      "limit": 10,
      "settings": [
        { "type": "video", "id": "video", "label": "Video" },
        { "type": "image_picker", "id": "image", "label": "Poster image" },
        { "type": "text", "id": "alt", "label": "Alt text", "default": "Customer review" },
        { "type": "text", "id": "fallback_text", "label": "Fallback text", "default": "Nerdy Nuts" }
      ]
    }
  ],
  "presets": [
    {
      "name": "WayMakers reviews",
      "blocks": [{ "type": "review" }, { "type": "review" }, { "type": "review" }, { "type": "review" }, { "type": "review" }]
    }
  ]
}
{% endschema %}
