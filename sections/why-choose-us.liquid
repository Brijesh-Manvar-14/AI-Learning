{%- comment -%}
  Why Choose Us — Waymakers Theme
  Pixel-matched from Figma: light-cyan bg · 2-col grid ·
  orange accent block · Lilita One heading · orange star deco · pill CTA
{%- endcomment -%}

{%- liquid
  assign wcu_arrow = 'wm-arrow.svg' | asset_url
-%}

<section
  class="wcu-section"
  id="why-choose-us-{{ section.id }}"
  aria-labelledby="wcu-title-{{ section.id }}"
  style="--wcu-bg: {{ section.settings.background_color }};"
>
  <div class="wcu-container">

    {%- comment -%} ── LEFT: image column ── {%- endcomment -%}
    <div class="wcu-media" aria-hidden="true">
      <div class="wcu-media__block"></div>

      {%- if section.settings.main_image != blank -%}
        <img
          class="wcu-media__main"
          src="{{ section.settings.main_image | image_url: width: 900 }}"
          alt=""
          width="438"
          height="563"
          loading="lazy"
        >
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'wcu-media__placeholder' }}
      {%- endif -%}

      {%- if section.settings.side_image != blank -%}
        <img
          class="wcu-media__side"
          src="{{ section.settings.side_image | image_url: width: 420 }}"
          alt=""
          width="183"
          height="357"
          loading="lazy"
        >
      {%- endif -%}

      {%- if section.settings.badge_image != blank -%}
        <img
          class="wcu-media__badge"
          src="{{ section.settings.badge_image | image_url: width: 260 }}"
          alt=""
          width="131"
          height="131"
          loading="lazy"
        >
      {%- endif -%}
    </div>

    {%- comment -%} ── RIGHT: content column ── {%- endcomment -%}
    <div class="wcu-content">

      {%- comment -%} Orange asterisk star decoration {%- endcomment -%}
      <span class="wcu-star" aria-hidden="true">
        <svg viewBox="0 0 60 60" width="52" height="52" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M30 2 L33.5 26.5 L58 30 L33.5 33.5 L30 58 L26.5 33.5 L2 30 L26.5 26.5 Z" fill="#fea36d"/>
          <path d="M30 11 L32 26.5 L47.5 30 L32 33.5 L30 49 L28 33.5 L12.5 30 L28 26.5 Z" fill="#fea36d" opacity="0"/>
          <path d="M12 12 L27.5 27.5 M47.5 12.5 L32 28 M48 48 L32.5 32.5 M12 48 L27.5 32.5" stroke="#fea36d" stroke-width="4.5" stroke-linecap="round"/>
        </svg>
      </span>

      <h2 id="wcu-title-{{ section.id }}" class="wcu-title">
        {{- section.settings.heading | default: 'MEER DAN ALLEEN PINDAKAAS' -}}
      </h2>

      {%- if section.settings.text != blank -%}
        <p class="wcu-text">{{ section.settings.text }}</p>
      {%- endif -%}

      {%- comment -%} Optional feature blocks {%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        <ul class="wcu-features" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' -%}
              <li class="wcu-feature" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  <img
                    class="wcu-feature__icon"
                    src="{{ block.settings.icon | image_url: width: 48 }}"
                    alt=""
                    width="24"
                    height="24"
                    loading="lazy"
                  >
                {%- else -%}
                  <span class="wcu-feature__dot" aria-hidden="true"></span>
                {%- endif -%}
                <span class="wcu-feature__text">{{ block.settings.text }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a
          class="wcu-btn"
          href="{{ section.settings.button_link | default: '#' }}"
          {%- if section.settings.button_link == blank %} aria-disabled="true"{% endif %}
        >
          {{- section.settings.button_label -}}
          <img src="{{ wcu_arrow }}" alt="" width="8" height="13" loading="lazy">
        </a>
      {%- endif -%}

    </div>

  </div>
</section>

{% stylesheet %}
/* ==========================================================
   WHY CHOOSE US — Waymakers Theme
   Pixel-matched from Figma:
   · light-cyan bg (#d9f3f7)
   · 2-col grid  minmax(420,688px) / minmax(0,739px)  gap 73px
   · orange accent block (#fea36d) + layered product images
   · orange 6-pt asterisk star decoration
   · Lilita One heading · Kanit 22px body · pill CTA
   ========================================================== */

.wcu-section {
  background-color: var(--wcu-bg, #d9f3f7);
  padding: 0;
}

.wcu-container {
  display: grid;
  grid-template-columns: minmax(420px, 688px) minmax(0, 739px);
  align-items: center;
  gap: 73px;
  width: min(1500px, calc(100vw - 48px));
  margin: 100px auto;
}

/* ----------------------------------------------------------
   IMAGE COLUMN
   ---------------------------------------------------------- */
.wcu-media {
  position: relative;
  min-height: 616px;
}

/* Orange rounded accent block behind the images */
.wcu-media__block {
  position: absolute;
  left: 0;
  bottom: 0;
  width: 645px;
  max-width: 94%;
  height: 483px;
  border-radius: 40px;
  background: #fea36d;
}

/* Main product image */
.wcu-media__main {
  position: absolute;
  left: 40px;
  top: 5px;
  width: 438px;
  max-width: 68%;
  height: 563px;
  object-fit: cover;
  display: block;
}

/* Secondary/side image */
.wcu-media__side {
  position: absolute;
  right: 54px;
  top: 168px;
  width: 183px;
  height: 357px;
  object-fit: cover;
  display: block;
}

/* Badge (round) */
.wcu-media__badge {
  position: absolute;
  right: 0;
  top: 58px;
  width: 131px;
  height: 131px;
  object-fit: contain;
  display: block;
}

/* Placeholder when no image uploaded */
.wcu-media__placeholder {
  position: absolute;
  left: 40px;
  top: 5px;
  width: 438px;
  max-width: 68%;
  height: 563px;
  background: #f7f7f7;
}

/* ----------------------------------------------------------
   CONTENT COLUMN
   ---------------------------------------------------------- */
.wcu-content {
  padding-right: 20px;
}

/* Orange 6-point asterisk star decoration */
.wcu-star {
  display: block;
  margin-bottom: 16px;
  line-height: 1;
}

/* Heading */
.wcu-title {
  font-family: "Lilita One", serif;
  font-size: 64px;
  font-weight: 400;
  line-height: 1.15;
  text-transform: uppercase;
  color: #000000;
  margin: 0;
  letter-spacing: -0.01em;
}

/* Body text */
.wcu-text {
  margin: 20px 0 30px;
  color: #000000;
  font: 400 22px/1.6 Kanit, var(--font-body-family, sans-serif);
  letter-spacing: 0;
}

/* Feature list (optional blocks) */
.wcu-features {
  list-style: none;
  margin: 0 0 28px;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.wcu-feature {
  display: flex;
  align-items: center;
  gap: 12px;
  font: 500 16px/1.4 Kanit, var(--font-body-family, sans-serif);
  color: #000000;
}

.wcu-feature__icon {
  flex-shrink: 0;
  width: 24px;
  height: 24px;
  object-fit: contain;
}

.wcu-feature__dot {
  flex-shrink: 0;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #fea36d;
}

/* CTA button — Waymakers pill, 3D border */
.wcu-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  min-height: 52px;
  padding: 14px 28px;
  background: #000000;
  color: #ffffff;
  border: 1px solid #000000;
  border-right-width: 3px;
  border-bottom-width: 3px;
  border-radius: 61px;
  font: 500 18px/1.3 Kanit, var(--font-body-family, sans-serif);
  text-transform: uppercase;
  text-decoration: none;
  letter-spacing: 0;
  transition: background 0.2s ease, color 0.2s ease, transform 0.1s ease;
}

.wcu-btn:hover {
  background: #ffd11f;
  color: #000000;
  border-color: #000000;
}

.wcu-btn:active {
  transform: translate(2px, 2px);
}

/* ----------------------------------------------------------
   RESPONSIVE
   ---------------------------------------------------------- */
@media (max-width: 1100px) {
  .wcu-title {
    font-size: 48px;
  }

  .wcu-container {
    gap: 48px;
  }
}

@media (max-width: 749px) {
  .wcu-container {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin: 50px auto;
  }

  /* On mobile: content goes above the image */
  .wcu-content {
    order: -1;
    padding-right: 0;
  }

  .wcu-title {
    font-size: 40px;
  }

  .wcu-text {
    font-size: 16px;
    line-height: 1.62;
    margin-top: 20px;
  }

  .wcu-star svg {
    width: 38px;
    height: 38px;
  }

  .wcu-btn {
    min-height: 46px;
    font-size: 16px;
    padding: 12px 24px;
  }

  .wcu-media {
    width: 100%;
    min-height: 316px;
  }

  .wcu-media__block {
    width: 94%;
    height: 248px;
    border-radius: 16px;
  }

  .wcu-media__main {
    left: 20px;
    top: 2px;
    width: 64%;
    height: 290px;
  }

  .wcu-media__side {
    right: 28px;
    top: 86px;
    width: 94px;
    height: 184px;
  }

  .wcu-media__badge {
    right: 0;
    top: 30px;
    width: 68px;
    height: 68px;
  }

  .wcu-media__placeholder {
    left: 20px;
    top: 2px;
    width: 64%;
    height: 290px;
  }
}

@media (max-width: 480px) {
  .wcu-title {
    font-size: 32px;
  }

  .wcu-text {
    font-size: 15px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Why Choose Us",
  "tag": "section",
  "class": "why-choose-us-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main product image"
    },
    {
      "type": "image_picker",
      "id": "side_image",
      "label": "Side product image (optional)"
    },
    {
      "type": "image_picker",
      "id": "badge_image",
      "label": "Badge / seal image (optional)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "MEER DAN ALLEEN PINDAKAAS"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body text",
      "default": "Bij WayMakers verkopen we de meest creatieve en lekkerste smaken pindakaas van Nederland. Unieke combinaties die je nergens anders vindt, handgemaakt met zorgvuldig geselecteerde ingrediënten. Geen massaproductie, maar ambachtelijke kwaliteit. Plus: 10% van onze winst gaat naar initiatieven die écht impact maken."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Lees Meer"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background color",
      "default": "#d9f3f7"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature item",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image (optional)"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Feature text",
          "default": "100% ambachtelijk gemaakt"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us"
    }
  ]
}
{% endschema %}
